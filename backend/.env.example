# ========================================
# SharePlate Backend Environment Variables.
# Clearly organized sections for each configuration area.
# Includes concise comments explaining the purpose of every variable, 
# along with best practices for setting values in development and production environments.
# ========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# ========================================
# Database Configuration
# ========================================
# MongoDB connection URI
# For development, use local MongoDB or MongoDB Atlas
MONGO_URI=mongodb://localhost:27017/shareplate_db
# Example Atlas URI format:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority&appName=app-name

# ========================================
# JWT (JSON Web Token) Configuration
# ========================================
# Access token secret (use a strong random string in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token secret (must be different from access secret)
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# Password Security Configuration
# ========================================
# Number of salt rounds for bcrypt password hashing
# Recommended: 10-12 (higher = slower but more secure)
# Note: 12 rounds is recommended for production
BCRYPT_SALT_ROUNDS=12

# ========================================
# Cookie Configuration
# ========================================
# Set to 'true' in production (requires HTTPS)
# Set to 'false' in development (allows HTTP)
COOKIE_SECURE=false

# Cookie domain (optional, usually not needed)
# COOKIE_DOMAIN=localhost

# ========================================
# CORS Configuration (if needed)
# ========================================
# Frontend URL for browser-facing auth links and CORS policy
# In local Vite development this is usually:
# FRONTEND_URL=http://localhost:5173

# ========================================
# Email Configuration (for future features)
# ========================================
# SMTP Email service configuration (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@shareplate.com

# ========================================
# Logging Configuration (optional)
# ========================================
# LOG_LEVEL=info
# Could be: debug, info, warn, error

# ========================================
# Production-Only Variables
# ========================================
# These should only be set in production environments
# SENTRY_DSN=your-sentry-error-tracking-url

# ========================================
# Cloudinary Configuration
# ========================================
# Get these from your Cloudinary Dashboard (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_registration_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
